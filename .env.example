# Get your CLIENT_ID from https://console.developers.google.com/
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# TODO(developer): Set the Apps Script deployment ID to api.gs
VITE_GOOGLE_APPS_SCRIPT_ID=your_google_app_script_id

# TODO(developer): Set the Google Search Console verification code
# 1. Go to https://search.google.com/search-console
# 2. Add property: https://<user>.github.io/your-reservoir-rises
# 3. Choose "HTML tag" method
# 4. Copy only the content value (e.g., "abc123xyz...")
VITE_GOOGLE_SITE_VERIFICATION=your_google_site_verification_code
